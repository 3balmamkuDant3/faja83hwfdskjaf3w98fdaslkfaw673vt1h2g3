function DropDown:setupSafeEsp()
    local workspace = game:GetService("Workspace")
    
    local function createHighlight(safe, safeName)
        if self.safeHighlights[safeName] then
            self.safeHighlights[safeName]:Destroy()
        end
        if self.safeBillboards[safeName] then
            self.safeBillboards[safeName]:Destroy()
        end
        
        local highlight = Instance.new("Highlight")
        highlight.Parent = game:GetService("CoreGui")
        highlight.Adornee = safe
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        self.safeHighlights[safeName] = highlight
        
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "SafeInfo"
        billboard.Adornee = safe
        billboard.Size = UDim2.new(0, 150, 0, 80)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.AlwaysOnTop = true
        billboard.Parent = game:GetService("CoreGui")
        
        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        textLabel.TextStrokeTransparency = 0
        textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        textLabel.TextSize = 6
        textLabel.TextScaled = false
        textLabel.Parent = billboard
        self.safeBillboards[safeName] = billboard
        
        safe.AncestryChanged:Connect(function()
            if not safe:IsDescendantOf(workspace) then
                if self.safeHighlights[safeName] then
                    self.safeHighlights[safeName].Enabled = false
                end
                if self.safeBillboards[safeName] then
                    self.safeBillboards[safeName].Enabled = false
                end
            end
        end)
    end

    self.safeEspCoroutine = coroutine.create(function()
        while self.isSafeEspEnabled do
            for _, safeName in ipairs(SafeNames) do
                local success, safe = pcall(function()
                    return workspace.Map.BredMakurz:FindFirstChild(safeName)
                end)
                
                if success and safe then
                    if not self.safeHighlights[safeName] or not self.safeHighlights[safeName].Parent then
                        createHighlight(safe, safeName)
                    end
                    
                    if self.safeHighlights[safeName] then
                        self.safeHighlights[safeName].Adornee = safe
                    end
                    if self.safeBillboards[safeName] then
                        self.safeBillboards[safeName].Adornee = safe
                    end
                    
                    local isBroken = false
                    local resetTime = 0
                    
                    pcall(function()
                        local values = safe:FindFirstChild("Values")
                        if values then
                            local broken = values:FindFirstChild("Broken")
                            if broken then
                                isBroken = broken.Value
                            end
                        end
                        
                        if not isBroken then
                            local interact = safe:FindFirstChild("Interact")
                            if interact then
                                isBroken = interact:GetAttribute("Broken") or false
                            end
                        end
                        
                        if not isBroken then
                            local openSound = safe:FindFirstChild("OpenSound")
                            if openSound and openSound:IsA("Sound") then
                                isBroken = openSound.Playing
                            end
                        end
                        
                        if isBroken then
                            if not self.safeResetTimers[safeName] then
                                self.safeResetTimers[safeName] = 720
                            else
                                self.safeResetTimers[safeName] = math.max(self.safeResetTimers[safeName] - 1, 0)
                            end
                            resetTime = self.safeResetTimers[safeName]
                        else
                            self.safeResetTimers[safeName] = nil
                        end
                    end)
                    
                    local highlight = self.safeHighlights[safeName]
                    local billboard = self.safeBillboards[safeName]
                    
                    if highlight and billboard then
                        highlight.FillColor = isBroken and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0)
                        highlight.Enabled = true
                        
                        local minutes = math.floor(resetTime / 60)
                        local seconds = resetTime % 60
                        local timeText = isBroken and string.format("%d:%02d", minutes, seconds) or ""
                        
                        billboard.TextLabel.Text = timeText
                        billboard.Enabled = true
                    end
                else
                    if self.safeHighlights[safeName] then
                        self.safeHighlights[safeName].Enabled = false
                    end
                    if self.safeBillboards[safeName] then
                        self.safeBillboards[safeName].Enabled = false
                    end
                end
            end
            wait(1)
        end
    end)
    coroutine.resume(self.safeEspCoroutine)
    
    local bredMakurz = workspace.Map:FindFirstChild("BredMakurz")
    if bredMakurz then
        bredMakurz.ChildAdded:Connect(function(child)
            if table.find(SafeNames, child.Name) then
                wait(0.5)
                if self.isSafeEspEnabled then
                    createHighlight(child, child.Name)
                end
            end
        end)
    end
end

