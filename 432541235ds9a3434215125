function DropDown:setupEvents()
    self.menuVisible = false
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if input.KeyCode == Enum.KeyCode.RightShift and not gameProcessed then
            self.menuVisible = not self.menuVisible
            local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            if self.menuVisible then
                self.screenGui.Enabled = true
                local fadeIn = TweenService:Create(self.mainFrame, tweenInfo, {BackgroundTransparency = 0.2})
                local scaleIn = TweenService:Create(self.mainFrame.UIScale, tweenInfo, {Scale = 1})
                fadeIn:Play()
                scaleIn:Play()
            else
                local fadeOut = TweenService:Create(self.mainFrame, tweenInfo, {BackgroundTransparency = 1})
                local scaleOut = TweenService:Create(self.mainFrame.UIScale, tweenInfo, {Scale = 0})
                fadeOut:Play()
                scaleOut:Play()
                fadeOut.Completed:Connect(function()
                    self.screenGui.Enabled = false
                end)
            end
        end
    end)

    player.CharacterAdded:Connect(function(character)
        hrp = character:WaitForChild("HumanoidRootPart")
        humanoid = character:WaitForChild("Humanoid")
        if self.isRunning then
            if self.isWaitingForAllowance then
                local idlePos = {CFrame = idlePosition}
                local idleInfo = TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
                local idleAnim = TweenService:Create(hrp, idleInfo, idlePos)
                idleAnim:Play()
            else
                local safezoneTime = self:calculateSafezoneTime()
                local safezoneInfo = TweenInfo.new(safezoneTime, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
                local animstart = TweenService:Create(hrp, safezoneInfo, safezone)
                animstart:Play()
            end
        end
        if self.isInfStaminaEnabled then
            local hum = character:WaitForChild("Humanoid")
            hum:SetAttribute("ZSPRN_M", true)
        else
            local hum = character:WaitForChild("Humanoid")
            hum:SetAttribute("ZSPRN_M", nil)
        end
    end)
end

function DropDown:calculateSafezoneTime()
    local distance = (hrp.Position - safezone.CFrame.Position).Magnitude
    if distance > 1500 or distance > 1000 then
        return 20
    elseif distance > 700 then
        return 16
    elseif distance > 500 then
        return 12
    elseif distance > 300 then
        return 7
    elseif distance > 150 then
        return 3
    elseif distance > 50 then
        return 1
    else
        return 1
    end
end

function DropDown:GetATM()
    local targetPos = atmnumb == 1 and atm1Pos or atm2Pos
    local closestPart, minDistance = nil, math.huge
    for _, v in ipairs(game:GetService("Workspace").Map.ATMz:GetChildren()) do
        if v:FindFirstChild("MainPart") then
            local distance = (targetPos - v.MainPart.Position).Magnitude
            if distance < minDistance and distance < 1 then
                minDistance = distance
                closestPart = v.MainPart
            end
        end
    end
    return closestPart
end

function DropDown:GetClosestPlayer()
    local closestDistance = math.huge
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= self.player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (hrp.Position - otherPlayer.Character.HumanoidRootPart.Position).Magnitude
            if distance < closestDistance then
                closestDistance = distance
            end
        end
    end
    return closestDistance
end

